{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grouter Switcher",
  "version": "0.1.0",
  "identifier": "com.grouter.switcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "grouter Switcher",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "minimizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
