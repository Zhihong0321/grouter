# The subrouter API key/base URL and issued-key prefix are NOT env vars --
# configure them via the admin dashboard's Settings page after first deploy
# (stored in Postgres, editable anytime, never shown in plaintext again).

DATABASE_URL=postgres://postgres:postgres@localhost:55432/reseller
REDIS_URL=redis://localhost:6379

SESSION_SECRET=change-me-to-a-random-64-char-string

# Consumed once by `pnpm seed:admin`, not read at runtime after that
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me

PORT=8787
NODE_ENV=development
