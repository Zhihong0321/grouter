# The subrouter API key/base URL and issued-key prefix are NOT env vars --
# configure them via the admin dashboard's Settings page after first deploy
# (stored in Postgres, editable anytime, never shown in plaintext again).

DATABASE_URL=postgres://postgres:postgres@localhost:55432/reseller
REDIS_URL=redis://localhost:6379

SESSION_SECRET=change-me-to-a-random-64-char-string

# Required by POST /client/accounts (self-serve signup from the Tauri client
# app) so the public endpoint can't be spammed by a bot that finds the URL.
# Bake the same value into the app build.
CLIENT_BOOTSTRAP_SECRET=change-me-to-a-random-32-char-string

# Consumed once by `pnpm seed:admin`, not read at runtime after that
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me

PORT=8787
NODE_ENV=development

# SubRouter's API endpoints used by imported routing keys. Keep the OpenAI
# `/v1` URL and Anthropic-compatible URL separate when your supplier requires it.
SUBROUTER_UPSTREAM_BASE_URL=https://ai.orbitlink.me/v1
SUBROUTER_ANTHROPIC_BASE_URL=https://ai.orbitlink.me

# Reconcile SubRouter's actual quota charges to customer usage rows. This runs
# off the proxy request path; the database advisory lock makes it safe across
# restarts or multiple replicas.
SUBROUTER_ACTIVITY_SYNC_ENABLED=true
SUBROUTER_ACTIVITY_SYNC_INTERVAL_SECONDS=300
