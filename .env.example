# The real upstream subrouter key -- never exposed to clients, never commit the real value
SUBROUTER_API_KEY=sk-your-subrouter-key-here
SUBROUTER_BASE_URL=https://ai.orbitlink.me

DATABASE_URL=postgres://postgres:postgres@localhost:55432/reseller
REDIS_URL=redis://localhost:6379

SESSION_SECRET=change-me-to-a-random-64-char-string

# Consumed once by `pnpm seed:admin`, not read at runtime after that
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me

PORT=8787
NODE_ENV=development

# Brand prefix for issued client keys, e.g. sk-orbit-...
KEY_PREFIX=orbit
