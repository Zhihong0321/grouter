{
  "name": "claude-reseller-proxy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:dashboard": "pnpm --filter dashboard build",
    "build:backend": "tsc -p tsconfig.json",
    "build": "pnpm build:dashboard && pnpm build:backend",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate -j sql",
    "migrate:up": "node-pg-migrate -j sql up",
    "migrate:down": "node-pg-migrate -j sql down",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "check:subrouter": "node dist/subrouterCheck.js",
    "sync:subrouter": "node dist/subrouterSync.js",
    "sync:subrouter-keys": "node dist/subrouterKeySync.js",
    "sync:subrouter-models": "node dist/subrouterAvailableModelsSync.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.0",
    "@fastify/static": "^8.1.1",
    "bcryptjs": "^2.4.3",
    "eventsource-parser": "^3.0.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "json-bigint": "^1.0.0",
    "node-pg-migrate": "^7.9.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
